# ---------------------------------------------------------------------------
# SoroPay environment variables. Copy this file to .env.local and fill in
# only what you have — every value below has a safe fallback so the app
# runs fully on testnet with $0 in API costs out of the box.
# ---------------------------------------------------------------------------

# Network: "testnet" (default, safe) or "mainnet" (real funds)
NEXT_PUBLIC_STELLAR_NETWORK=testnet

# WalletConnect (for mobile wallets like Lobstr). Free project ID from
# https://cloud.reown.com — without it, Freighter/Albedo/xBull still work,
# just no mobile WalletConnect option in the wallet picker.
NEXT_PUBLIC_WALLETCONNECT_PROJECT_ID=

# Claude API (OPTIONAL upgrade for fuzzier natural-language parsing).
# Leave both unset/false to use the free local rule-based parser.
NEXT_PUBLIC_USE_CLAUDE_PARSER=false
ANTHROPIC_API_KEY=

# Soroswap aggregator API (OPTIONAL — multi-AMM swap routing upgrade).
# Leave unset to use the native Stellar DEX for swaps instead (works today).
NEXT_PUBLIC_SOROSWAP_API_URL=https://api.soroswap.finance
NEXT_PUBLIC_SOROSWAP_API_KEY=

# Supabase (OPTIONAL — shared/cloud contacts + history instead of localStorage).
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
